# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Required ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Model selection ───────────────────────────────────────────────────────────
OPENROUTER_CLASSIFIER_MODEL=openai/gpt-4o-mini
OPENROUTER_EXECUTOR_MODEL=openai/gpt-4o
OPENROUTER_VERIFIER_MODEL=openai/gpt-4o-mini
OPENROUTER_CRITIC_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# ── RAG settings ──────────────────────────────────────────────────────────────
OPENROUTER_CHUNK_WORD_LENGTH=150
OPENROUTER_TOP_K_CHUNKS=5

# ── Pipeline settings ─────────────────────────────────────────────────────────
OPENROUTER_MAX_RETRIES=3
OPENROUTER_ENABLE_DUAL_PATH=true

# ── CPHOS MySQL database (db_api) ─────────────────────────────────────────────
CPHOS_DB_HOST=
CPHOS_DB_PORT=3306
CPHOS_DB_USER=
CPHOS_DB_NAME=
CPHOS_DB_PASSWORD=
